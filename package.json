{
  "name": "test",
  "private": true,
  "version": "0.3.2",
  "description": "NKC serverless secure chat desktop app",
  "author": {
    "name": "NyuKoP",
    "email": "nyukop@users.noreply.github.com"
  },
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 vite dev",
    "generate:onion-pins": "node scripts/generateOnionPins.mjs",
    "generate:icons": "node scripts/generateAppIcon.mjs",
    "edit:win-exe": "node scripts/editWindowsExecutable.mjs",
    "lint:encoding": "node scripts/check-utf8.mjs",
    "build:native": "node scripts/build-go-worker.mjs",
    "test:native": "node scripts/test-go-worker.mjs",
    "build": "npm run build:native && cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tsc -b && cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 vite build",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
    "dist:win": "npm run generate:icons && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win dir --publish never && npm run edit:win-exe && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --prepackaged release/win-unpacked --publish never",
    "dist:mac": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --publish never",
    "dist:linux": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux AppImage deb --publish never",
    "test": "vitest",
    "test:tor:live": "npm run build:native && node scripts/run-live-tor-e2e.mjs",
    "test:tor:reinstall": "cross-env NKC_TOR_REINSTALL_LIVE=1 vitest run src/main/onion/install/__tests__/torReinstall.live.test.ts --reporter=verbose",
    "test:tor:large": "npm run build:native && node scripts/run-live-tor-e2e.mjs --large --size-mb=1",
    "test:tor:large:10": "npm run build:native && node scripts/run-live-tor-e2e.mjs --large --size-mb=10",
    "test:tor:large:100": "npm run build:native && node scripts/run-live-tor-e2e.mjs --large --size-mb=100",
    "test:tor:large:500": "npm run build:native && node scripts/run-live-tor-e2e.mjs --large --size-mb=500",
    "bench:transfer": "vitest bench --run src/perf/transferEncoding.bench.ts",
    "bench:transfer:500mb": "cross-env NKC_LARGE_TRANSFER_BENCH=1 vitest run src/perf/largeTransferPipeline.test.ts --reporter=verbose",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:packaged:first-run": "node scripts/verify-packaged-first-run.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node scripts/start-electron.cjs",
    "analyze:router-errors": "node scripts/analyze-router-errors.cjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-tabs": "^1.1.4",
    "dexie": "^4.0.8",
    "libsodium-wrappers": "^0.7.13",
    "libsodium-wrappers-sumo": "^0.7.13",
    "lucide-react": "^0.471.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.1.5",
    "ws": "^8.21.0",
    "yjs": "^13.6.22",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.49",
    "resedit-cli": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "3.2.6"
  },
  "build": {
    "appId": "com.nyukop.nkc",
    "productName": "NKC",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "native/bin",
        "to": "native",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "NyuKoP <nyukop@users.noreply.github.com>"
    }
  }
}
